# SmartRoute Agent 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# LLM 服务配置
# ============================================
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_GPT4O=gpt-4o
OPENAI_MODEL_GPT4O_MINI=gpt-4o-mini

ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL_CLAUDE=claude-3-5-sonnet-20241022

# 阿里云通义千问（备用）
QWEN_API_KEY=xxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_MODEL=qwen-max

# ============================================
# 数据库配置
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=smartroute
POSTGRES_PASSWORD=xxx
POSTGRES_DB=smartroute

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Milvus 向量数据库
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_POI=poi_embeddings
MILVUS_COLLECTION_USER=user_profiles

# Elasticsearch
ES_HOST=localhost
ES_PORT=9200
ES_USER=elastic
ES_PASSWORD=xxx

# ClickHouse（日志存储）
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=smartroute_logs

# ============================================
# 外部 API 配置
# ============================================
# 高德地图
AMAP_API_KEY=xxx
AMAP_BASE_URL=https://restapi.amap.com/v3

# 大众点评/美团
DIANPING_API_KEY=xxx
DIANPING_BASE_URL=https://api.dianping.com/v1

# 和风天气
QWEATHER_API_KEY=xxx
QWEATHER_BASE_URL=https://api.qweather.com/v7

# ============================================
# 服务配置
# ============================================
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Session 配置
SESSION_TTL_SECONDS=86400
SESSION_REDIS_PREFIX=session:

# 缓存配置
UGC_CACHE_TTL_SECONDS=604800
POI_CACHE_TTL_SECONDS=3600

# ============================================
# 性能参数
# ============================================
LLM_TIMEOUT_SECONDS=10
ROUTE_SOLVE_TIMEOUT_SECONDS=2
STREAM_FIRST_TOKEN_TARGET_SECONDS=2

# 召回配置
RETRIEVAL_TOP_K=50
CANDIDATE_POOL_SIZE=20
ROUTE_PLAN_COUNT=3
MAX_POI_OVERLAP_RATIO=0.5

# ============================================
# 监控配置
# ============================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=smartroute-agent

PROMETHEUS_PORT=9090

# ============================================
# 特征存储（Feast）
# ============================================
FEAST_ONLINE_STORE_HOST=localhost
FEAST_OFFLINE_STORE_PATH=data/features/

# ============================================
# 成本控制
# ============================================
LLM_BUDGET_PER_REQUEST_YUAN=0.20
BUDGET_ALERT_RATIO=1.2